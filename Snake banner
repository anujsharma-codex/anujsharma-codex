<svg viewBox="0 0 960 180" xmlns="http://www.w3.org/2000/svg" width="100%">
  <defs>

    <style>
      .eye-glow   { animation: eye-pulse 2.5s ease-in-out infinite; }
      .fang       { animation: fang-show 5s ease-in-out infinite; }
      .venom-drop { animation: venom-drip 5s ease-in-out infinite; }
      .tongue     { animation: tongue-show 5s ease-in-out infinite; }
      .body-shine { animation: shine-pulse 3s ease-in-out infinite; }

      @keyframes eye-pulse {
        0%, 100% { filter: drop-shadow(0 0 3px #ff8800) drop-shadow(0 0 6px #cc5500); }
        50%       { filter: drop-shadow(0 0 10px #ffcc00) drop-shadow(0 0 22px #ff8800); }
      }
      @keyframes fang-show {
        0%,   27% { opacity: 0; }
        37%,  63% { opacity: 1; }
        73%, 100% { opacity: 0; }
      }
      @keyframes venom-drip {
        0%,   38% { opacity: 0; transform: translateY(0px);  }
        42%       { opacity: 1; transform: translateY(0px);  }
        62%       { opacity: 0.7; transform: translateY(16px); }
        72%, 100% { opacity: 0; transform: translateY(20px); }
      }
      @keyframes tongue-show {
        0%,   67% { opacity: 0; }
        75%,  90% { opacity: 1; }
        97%, 100% { opacity: 0; }
      }
      @keyframes shine-pulse {
        0%, 100% { opacity: 0.22; }
        50%       { opacity: 0.42; }
      }
    </style>

    <!-- Body gradient (tail → head) -->
    <linearGradient id="body-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#0d0017"/>
      <stop offset="50%"  stop-color="#2d0060"/>
      <stop offset="100%" stop-color="#3d0075"/>
    </linearGradient>

    <!-- Head gradient -->
    <linearGradient id="head-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#3d0075"/>
      <stop offset="100%" stop-color="#250055"/>
    </linearGradient>

    <!-- Outer neon glow for body -->
    <filter id="body-glow" x="-10%" y="-80%" width="120%" height="260%">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- Eye filter -->
    <filter id="eye-f" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="2.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- Fang glow -->
    <filter id="fang-glow" x="-40%" y="-20%" width="180%" height="160%">
      <feGaussianBlur stdDeviation="1.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

  </defs>


  <!-- ═══════════════════  B O D Y  ═══════════════════ -->

  <!-- Outer neon glow halo -->
  <path class="body-shine"
    d="M 22,90 C 62,44 112,136 160,90 C 208,44 258,136 306,90
       C 354,44 404,136 452,90 C 500,44 550,136 598,90
       C 646,44 696,136 722,90 C 755,62 800,74 838,90"
    fill="none" stroke="#9d00ff" stroke-width="34" stroke-linecap="round"
    filter="url(#body-glow)"/>

  <!-- Main body -->
  <path
    d="M 22,90 C 62,44 112,136 160,90 C 208,44 258,136 306,90
       C 354,44 404,136 452,90 C 500,44 550,136 598,90
       C 646,44 696,136 722,90 C 755,62 800,74 838,90"
    fill="none" stroke="url(#body-grad)" stroke-width="24" stroke-linecap="round"/>

  <!-- Dorsal stripe (spine highlight) -->
  <path
    d="M 22,90 C 62,44 112,136 160,90 C 208,44 258,136 306,90
       C 354,44 404,136 452,90 C 500,44 550,136 598,90
       C 646,44 696,136 722,90 C 755,62 800,74 838,90"
    fill="none" stroke="#ff00ff" stroke-width="1.8" stroke-linecap="round"
    stroke-dasharray="12 10" opacity="0.55"/>

  <!-- Body edge highlight (top) -->
  <path
    d="M 22,90 C 62,44 112,136 160,90 C 208,44 258,136 306,90
       C 354,44 404,136 452,90 C 500,44 550,136 598,90
       C 646,44 696,136 722,90 C 755,62 800,74 838,90"
    fill="none" stroke="#7b00ff" stroke-width="2.5" stroke-linecap="round"
    opacity="0.5"/>

  <!-- Tail taper -->
  <path d="M 22,90 C 15,87 11,83 9,79 C 7,75 8,72 10,71"
    fill="none" stroke="#1a0030" stroke-width="9" stroke-linecap="round"/>
  <path d="M 10,71 C 11,70 12,70 12,71"
    fill="none" stroke="#0d0017" stroke-width="4" stroke-linecap="round"/>


  <!-- ═══════════════════  H E A D  ═══════════════════ -->

  <!-- UPPER JAW — static triangular viper shape -->
  <polygon points="924,90 838,52 836,90"
    fill="url(#head-grad)" stroke="#7b00ff" stroke-width="1.8" stroke-linejoin="round"/>

  <!-- Scale lines on upper jaw -->
  <path d="M 840,63 Q 873,70 912,88" fill="none" stroke="#5500aa" stroke-width="1" opacity="0.55"/>
  <path d="M 841,72 Q 868,77 905,88" fill="none" stroke="#5500aa" stroke-width="1" opacity="0.38"/>
  <path d="M 840,80 Q 862,82 897,89" fill="none" stroke="#5500aa" stroke-width="0.8" opacity="0.28"/>

  <!-- Upper jaw sharp edge highlight -->
  <path d="M 838,52 L 922,89" fill="none" stroke="#9d00ff" stroke-width="1.8" opacity="0.7"/>

  <!-- LOWER JAW — rotates open around point (836, 90) -->
  <g id="lower-jaw">
    <animateTransform attributeName="transform" type="rotate"
      values="0,836,90; 0,836,90; 0,836,90; 27,836,90; 27,836,90; 27,836,90; 0,836,90; 0,836,90"
      keyTimes="0; 0.1; 0.27; 0.37; 0.47; 0.63; 0.73; 1"
      dur="5s" repeatCount="indefinite"
      calcMode="spline"
      keySplines="0.4 0 0.6 1; 0.4 0 0.6 1; 0.15 0 0.15 1; 0.4 0 0.6 1; 0.4 0 0.6 1; 0.15 0 0.15 1; 0.4 0 0.6 1"/>

    <!-- Lower jaw shape -->
    <polygon points="924,90 836,90 838,128"
      fill="url(#head-grad)" stroke="#7b00ff" stroke-width="1.8" stroke-linejoin="round"/>

    <!-- Scale lines on lower jaw -->
    <path d="M 840,118 Q 868,108 906,91" fill="none" stroke="#5500aa" stroke-width="1" opacity="0.5"/>
    <path d="M 840,110 Q 864,103 900,91" fill="none" stroke="#5500aa" stroke-width="0.8" opacity="0.32"/>

    <!-- Lower jaw edge -->
    <path d="M 838,128 L 922,91" fill="none" stroke="#7b00ff" stroke-width="1.2" opacity="0.55"/>
  </g>


  <!-- ═══════════════════  F A N G  ═══════════════════ -->
  <!-- Hangs from upper jaw — shown only when mouth is open -->
  <g class="fang" filter="url(#fang-glow)">
    <!-- Fang shape: curved hollow tube -->
    <path d="M 891,90 C 888,96 883,112 885,120 C 887,124 891,124 892,120 C 894,112 894,96 891,90 Z"
      fill="#dde0ff" stroke="#ffffff" stroke-width="0.9"/>
    <!-- Hollow groove on fang -->
    <path d="M 891,93 C 890,100 889,112 890,119"
      fill="none" stroke="#aaaacc" stroke-width="0.7"/>
    <!-- Fang tip highlight -->
    <circle cx="888" cy="121" r="1.5" fill="#ffffff" opacity="0.7"/>
  </g>

  <!-- VENOM DROP -->
  <ellipse class="venom-drop" cx="887" cy="124" rx="2.8" ry="3.8"
    fill="#00ff99" opacity="0"/>


  <!-- ═══════════════════  E Y E  ═══════════════════ -->
  <g class="eye-glow" filter="url(#eye-f)">
    <!-- Socket -->
    <ellipse cx="864" cy="71" rx="10" ry="9" fill="#0d0017"/>
    <!-- Outer iris -->
    <ellipse cx="864" cy="71" rx="8.5" ry="7.5" fill="#bb5500"/>
    <!-- Inner iris -->
    <ellipse cx="864" cy="71" rx="6.5" ry="6" fill="#ff8800"/>
    <!-- Vertical slit pupil — viper characteristic -->
    <ellipse cx="864" cy="71" rx="2.2" ry="6" fill="#000000"/>
    <!-- Pupil depth -->
    <ellipse cx="864" cy="71" rx="1.2" ry="3" fill="#1a0500" opacity="0.7"/>
    <!-- Specular highlight -->
    <circle cx="866.5" cy="68.5" r="2" fill="#ffffff" opacity="0.9"/>
    <!-- Glow ring -->
    <ellipse cx="864" cy="71" rx="10" ry="9" fill="none"
      stroke="#ff8800" stroke-width="1.5" opacity="0.45"/>
  </g>

  <!-- Brow ridge — gives the aggressive, dangerous look -->
  <path d="M 855,62 Q 864,57 873,61"
    fill="none" stroke="#4400aa" stroke-width="3.5" stroke-linecap="round" opacity="0.9"/>

  <!-- Nostril / pit organ (heat-sensing pit of a viper) -->
  <ellipse cx="908" cy="83" rx="2.2" ry="1.6" fill="#0d0017" opacity="0.95"/>
  <circle  cx="908" cy="83" r="1.1"  fill="#000000"/>


  <!-- ═══════════════════  T O N G U E  ═══════════════════ -->
  <!-- Flicks out AFTER mouth closes -->
  <g class="tongue">
    <!-- Tongue stem -->
    <line x1="924" y1="90" x2="950" y2="90"
      stroke="#ff1155" stroke-width="3.5" stroke-linecap="round"/>
    <!-- Fork left -->
    <line x1="950" y1="90" x2="959" y2="81"
      stroke="#ff1155" stroke-width="2.2" stroke-linecap="round"/>
    <!-- Fork right -->
    <line x1="950" y1="90" x2="959" y2="99"
      stroke="#ff1155" stroke-width="2.2" stroke-linecap="round"/>
  </g>

</svg>
